## FILE 5: Ansible Role — `fluent-bit/roles/fluentbit/tasks/main.yml`

This is the actual install logic — the role that both playbooks call via `import_role`:

```yaml
---
# ── Linux / RHEL ──────────────────────────────────────────────────────────────
- name: Add Fluent Bit GPG key (Linux)
  ansible.builtin.rpm_key:
    key: "{{ artifactory_url }}/fluent-bit/fluentbit.key"
    state: present
  when: ansible_system == "Linux"

- name: Add Fluent Bit yum repository (Linux)
  ansible.builtin.yum_repository:
    name: fluent-bit
    description: Fluent Bit
    baseurl: "{{ artifactory_url }}/fluent-bit/centos/$releasever/$basearch/"
    enabled: true
    gpgcheck: true
    gpgkey: "{{ artifactory_url }}/fluent-bit/fluentbit.key"
  when: ansible_system == "Linux"

- name: Install Fluent Bit (Linux)
  ansible.builtin.yum:
    name: fluent-bit
    state: "{{ fluentbit_state }}"
  when: ansible_system == "Linux"

- name: Create Fluent Bit config directory (Linux)
  ansible.builtin.file:
    path: "{{ item }}"
    state: directory
    mode: "0755"
  loop:
    - /etc/fluent-bit
    - /var/lib/fluent-bit
    - /var/log/siem
  when: ansible_system == "Linux"

- name: Write Fluent Bit config (Linux)
  ansible.builtin.template:
    src: fluent-bit-linux.conf.j2
    dest: /etc/fluent-bit/fluent-bit.conf
    mode: "0644"
  notify: Restart Fluent Bit Linux
  when: ansible_system == "Linux"

- name: Enable and start Fluent Bit service (Linux)
  ansible.builtin.systemd:
    name: fluent-bit
    enabled: true
    state: started
  when: ansible_system == "Linux" and fluentbit_state == "present"

# ── Windows ───────────────────────────────────────────────────────────────────
- name: Create Fluent Bit install directory (Windows)
  ansible.windows.win_file:
    path: 'C:\fluent-bit'
    state: directory
  when: ansible_system == "Win32NT"

- name: Download Fluent Bit package from Artifactory (Windows)
  ansible.windows.win_get_url:
    url: "{{ artifactory_url }}/fluent-bit/fluent-bit-3.2.7-win64.zip"
    dest: 'C:\fluent-bit\fluent-bit.zip'
  when: ansible_system == "Win32NT"

- name: Extract Fluent Bit (Windows)
  community.windows.win_unzip:
    src: 'C:\fluent-bit\fluent-bit.zip'
    dest: 'C:\fluent-bit'
    delete_archive: false
  when: ansible_system == "Win32NT"

- name: Write Fluent Bit config (Windows)
  ansible.windows.win_template:
    src: fluent-bit-windows.conf.j2
    dest: 'C:\fluent-bit\fluent-bit.conf'
  notify: Restart Fluent Bit Windows
  when: ansible_system == "Win32NT"

- name: Register Fluent Bit as Windows Service
  ansible.windows.win_service:
    name: FluentBit
    path: '"C:\fluent-bit\fluent-bit-3.2.7-win64\bin\fluent-bit.exe" -c "C:\fluent-bit\fluent-bit.conf"'
    display_name: Fluent Bit Log Shipper
    start_mode: auto
    state: "{{ fluentbit_state == 'present' | ternary('started', 'stopped') }}"
  when: ansible_system == "Win32NT"
```

