## SECTION 3: Inject Into Your Existing Terraform

### In your existing `modules/vm/main.tf` — add at the bottom:
```hcl
# ── INJECT: Fluent Bit for Linux VMs ──────────────────────
module "fluentbit_vm" {
  source = "../fluentbit-vm"

  linux_vm_ids = {
    for vm in azurerm_linux_virtual_machine.vms :
    vm.name => vm.id
  }

  windows_vm_ids = {
    for vm in azurerm_windows_virtual_machine.vms :
    vm.name => vm.id
  }

  splunk_hec_host  = var.splunk_hec_host
  splunk_hec_port  = var.splunk_hec_port
  splunk_hec_token = var.splunk_hec_token
  splunk_index_vm  = "vm-logs"
}
```

### In your existing `modules/aks/main.tf` — add at the bottom:
```hcl
# ── INJECT: Fluent Bit for AKS clusters ───────────────────
data "azurerm_kubernetes_cluster" "clusters" {
  for_each            = toset(var.cluster_names)
  name                = each.value
  resource_group_name = var.resource_group_name
}

module "fluentbit_aks" {
  source = "../fluentbit-aks"

  aks_clusters = {
    for name, cluster in data.azurerm_kubernetes_cluster.clusters : name => {
      host                   = cluster.kube_config[0].host
      cluster_ca_certificate = base64decode(cluster.kube_config[0].cluster_ca_certificate)
      token                  = cluster.kube_config[0].password
    }
  }

  splunk_hec_host  = var.splunk_hec_host
  splunk_hec_port  = var.splunk_hec_port
  splunk_hec_token = var.splunk_hec_token
  splunk_index_aks = "aks-logs"
}
```

