### `modules/fluentbit-vm/main.tf`
```hcl
# ══════════════════════════════════════════════════════════
# FLUENT BIT VM MODULE
# Supports: Windows VMs + Linux/RHEL VMs
# Target:   Splunk HEC (direct, no Event Hubs)
# ══════════════════════════════════════════════════════════

terraform {
  required_providers {
    azurerm = {
      source  = "hashicorp/azurerm"
      version = "~> 3.0"
    }
  }
}

# ── LINUX VMs (RHEL / Ubuntu) ──────────────────────────────
# Publisher: Microsoft.Azure.Extensions
# Type:      CustomScript v2.1
resource "azurerm_virtual_machine_extension" "fluentbit_linux" {
  for_each = var.linux_vm_ids

  name                 = "fluentbit-linux"
  virtual_machine_id   = each.value
  publisher            = "Microsoft.Azure.Extensions"
  type                 = "CustomScript"
  type_handler_version = "2.1"

  # Inline script: passes Splunk params as arguments
  settings = jsonencode({
    script = base64encode(file("${path.module}/scripts/install-linux.sh"))
  })

  protected_settings = jsonencode({
    commandToExecute = "bash install-linux.sh '${var.splunk_hec_host}' '${var.splunk_hec_port}' '${var.splunk_hec_token}' '${var.splunk_index_vm}'"
  })

  tags = {
    component = "log-shipper"
    tool      = "fluent-bit"
    os        = "linux"
    target    = "splunk-hec"
  }

  lifecycle {
    ignore_changes = [settings, protected_settings]
  }
}

# ── WINDOWS VMs ────────────────────────────────────────────
# Publisher: Microsoft.Compute
# Type:      CustomScriptExtension v1.10
resource "azurerm_virtual_machine_extension" "fluentbit_windows" {
  for_each = var.windows_vm_ids

  name                 = "fluentbit-windows"
  virtual_machine_id   = each.value
  publisher            = "Microsoft.Compute"
  type                 = "CustomScriptExtension"
  type_handler_version = "1.10"

  settings = jsonencode({
    fileUris = []
  })

  protected_settings = jsonencode({
    commandToExecute = "powershell -ExecutionPolicy Unrestricted -EncodedCommand ${base64encode(
      "param($h,$p,$t,$i) ${file("${path.module}/scripts/install-windows.ps1")}"
    )} -SplunkHost '${var.splunk_hec_host}' -SplunkPort '${var.splunk_hec_port}' -SplunkToken '${var.splunk_hec_token}' -SplunkIndex '${var.splunk_index_vm}'"
  })

  tags = {
    component = "log-shipper"
    tool      = "fluent-bit"
    os        = "windows"
    target    = "splunk-hec"
  }

  lifecycle {
    ignore_changes = [settings, protected_settings]
  }
}
```

