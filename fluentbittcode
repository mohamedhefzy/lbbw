## SECTION 1: Windows VMs → Fluent Bit → Splunk

### `modules/fluentbit-vm/scripts/install-windows.ps1`
```powershell
param(
  [string]$SplunkHost,
  [string]$SplunkPort  = "8088",
  [string]$SplunkToken,
  [string]$SplunkIndex = "vm-logs"
)

$ErrorActionPreference = "Stop"
$InstallDir = "C:\fluent-bit"

Write-Host "=== Installing Fluent Bit on Windows ==="

# 1. Create directories
New-Item -ItemType Directory -Force -Path $InstallDir | Out-Null
New-Item -ItemType Directory -Force -Path "C:\logs\siem" | Out-Null

# 2. Download Fluent Bit
$ZipUrl  = "https://packages.fluentbit.io/windows/fluent-bit-3.2.7-win64.zip"
$ZipPath = "$InstallDir\fluent-bit.zip"
Write-Host "Downloading Fluent Bit..."
Invoke-WebRequest -Uri $ZipUrl -OutFile $ZipPath -UseBasicParsing
Expand-Archive -Path $ZipPath -DestinationPath $InstallDir -Force
$BinPath = "$InstallDir\fluent-bit-3.2.7-win64\bin\fluent-bit.exe"

# 3. Write config
$Config = @"
[SERVICE]
    Flush           5
    Log_Level       info
    Daemon          off
    Parsers_File    $InstallDir\fluent-bit-3.2.7-win64\conf\parsers.conf

[INPUT]
    Name            tail
    Tag             vm.filelogs
    Path            C:\logs\siem\*.log,C:\inetpub\logs\LogFiles\*.log
    DB              $InstallDir\tail_file.db
    Skip_Long_Lines On
    Refresh_Interval 5

[INPUT]
    Name            winlog
    Tag             vm.winevents
    Channels        Security,System,Application
    Interval_Sec    5
    DB              $InstallDir\winlog.db

[FILTER]
    Name            record_modifier
    Match           *
    Record          hostname  $env:COMPUTERNAME
    Record          source    azure-vm-windows
    Record          index     $SplunkIndex

[OUTPUT]
    Name            splunk
    Match           *
    Host            $SplunkHost
    Port            $SplunkPort
    Splunk_Token    $SplunkToken
    Splunk_Send_Raw On
    TLS             On
    TLS.Verify      Off
    compress        gzip
    Retry_Limit     5
"@
$Config | Out-File -FilePath "$InstallDir\fluent-bit.conf" -Encoding UTF8

# 4. Register as Windows Service
$ExistingService = Get-Service -Name "FluentBit" -ErrorAction SilentlyContinue
if ($ExistingService) {
  Stop-Service -Name "FluentBit" -Force
  sc.exe delete "FluentBit" | Out-Null
  Start-Sleep -Seconds 2
}

New-Service `
  -Name        "FluentBit" `
  -BinaryPathName "`"$BinPath`" -c `"$InstallDir\fluent-bit.conf`"" `
  -DisplayName "Fluent Bit Log Shipper" `
  -StartupType  Automatic

Start-Service -Name "FluentBit"
Write-Host "=== Fluent Bit running as Windows Service -> Splunk HEC ==="
```

