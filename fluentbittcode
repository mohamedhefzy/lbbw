### `modules/fluentbit-vm/scripts/install-linux.sh`
```bash
#!/bin/bash
set -euo pipefail

SPLUNK_HOST="$1"
SPLUNK_PORT="${2:-8088}"
SPLUNK_TOKEN="$3"
SPLUNK_INDEX="${4:-vm-logs}"

echo "=== Installing Fluent Bit on Linux/RHEL ==="

# 1. Detect OS and install
if [ -f /etc/redhat-release ]; then
  echo "Detected RHEL/CentOS"
  # Import GPG key
  rpm --import https://packages.fluentbit.io/fluentbit.key

  # Add repo
  cat > /etc/yum.repos.d/fluent-bit.repo <<'REPO'
[fluent-bit]
name=Fluent Bit
baseurl=https://packages.fluentbit.io/centos/$releasever/$basearch/
enabled=1
gpgcheck=1
gpgkey=https://packages.fluentbit.io/fluentbit.key
REPO

  yum install -y fluent-bit
else
  echo "Detected Ubuntu/Debian"
  curl -fsSL https://raw.githubusercontent.com/fluent/fluent-bit/master/install.sh | sh
fi

# 2. Create directories
mkdir -p /etc/fluent-bit /var/lib/fluent-bit /var/log/siem

# 3. Write config
cat > /etc/fluent-bit/fluent-bit.conf <<CONF
[SERVICE]
    Flush           5
    Log_Level       info
    Daemon          off
    Parsers_File    /etc/fluent-bit/parsers.conf

[INPUT]
    Name            tail
    Tag             vm.applogs
    Path            /var/log/siem/*.log,/var/log/app/*.log
    DB              /var/lib/fluent-bit/tail_app.db
    Mem_Buf_Limit   10MB
    Skip_Long_Lines On
    Refresh_Interval 5

[INPUT]
    Name            systemd
    Tag             vm.syslog
    DB              /var/lib/fluent-bit/systemd.db
    Strip_Underscores On

[INPUT]
    Name            tail
    Tag             vm.secure
    Path            /var/log/secure,/var/log/auth.log
    DB              /var/lib/fluent-bit/secure.db
    Skip_Long_Lines On

[FILTER]
    Name            record_modifier
    Match           *
    Record          hostname  \${HOSTNAME}
    Record          source    azure-vm-linux
    Record          index     ${SPLUNK_INDEX}

[OUTPUT]
    Name            splunk
    Match           *
    Host            ${SPLUNK_HOST}
    Port            ${SPLUNK_PORT}
    Splunk_Token    ${SPLUNK_TOKEN}
    Splunk_Send_Raw On
    TLS             On
    TLS.Verify      Off
    compress        gzip
    Retry_Limit     5
CONF

# 4. Enable and start
systemctl enable fluent-bit
systemctl restart fluent-bit
echo "=== Fluent Bit running -> Splunk HEC ==="
systemctl status fluent-bit --no-pager
```

